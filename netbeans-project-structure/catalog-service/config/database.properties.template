# Environment-driven DB template for catalog-service
# Prefer setting CATALOG_DB_* env vars in Docker/Kubernetes.
# Fallback shared env vars are DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.

db.host=${CATALOG_DB_HOST}
db.port=${CATALOG_DB_PORT}
db.name=${CATALOG_DB_NAME}
db.user=${CATALOG_DB_USER}
db.password=${CATALOG_DB_PASSWORD}
