# Environment-driven DB template for auth-service
# Prefer setting AUTH_DB_* env vars in Docker/Kubernetes.
# Fallback shared env vars are DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.

db.host=${AUTH_DB_HOST}
db.port=${AUTH_DB_PORT}
db.name=${AUTH_DB_NAME}
db.user=${AUTH_DB_USER}
db.password=${AUTH_DB_PASSWORD}
